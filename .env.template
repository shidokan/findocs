# FinDocs AI Platform — environment configuration template.
# Copy this file to .env and fill in the values for your Azure subscription.
# Never commit the populated .env file — it is gitignored for a reason.

# ============================================================================
# Azure OpenAI / Foundry — for direct calls during local development.
# In production, the FastAPI service calls Azure OpenAI through the APIM
# gateway, not directly. These values are only used when running
# `python ingestion/edgar_fetcher.py` or `python api/findocs_rag.py` locally.
# ============================================================================
# From: Azure Portal → your Foundry resource → Resource Management → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-foundry-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key-1>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002

# ============================================================================
# Azure AI Search — per-tenant indexes
# ============================================================================
# From: Azure Portal → AI Search resource → Settings → Keys
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_API_KEY=<your-search-admin-key>

# For single-tenant local testing, set the active tenant index here.
# In production, the FastAPI service derives this from the X-Tenant-ID
# header that APIM sets after subscription-key lookup.
AZURE_SEARCH_INDEX=tech-filings

# ============================================================================
# Retrieval tuning
# ============================================================================
TOP_K=5

# ============================================================================
# SEC EDGAR ingestion
# ============================================================================
# Required by SEC's EDGAR rules — must be a real contact in case of issues.
# Format: "Your Name your.email@example.com"
SEC_USER_AGENT=John Carlo Cueva john.cueva@example.com

# Where ingestion writes downloaded filings before they go to blob storage.
EDGAR_OUTPUT_DIR=./filings

# ============================================================================
# APIM gateway (for end-to-end smoke testing against the deployed platform)
# ============================================================================
# Only needed when testing the gateway path locally; the values come from
# `terraform output tenant_subscriptions` after deploying infra.
GATEWAY_URL=https://<your-apim-instance>.azure-api.net
GATEWAY_KEY_TECH=<tech-tenant-subscription-key>
GATEWAY_KEY_BANKS=<banks-tenant-subscription-key>
GATEWAY_KEY_ENERGY=<energy-tenant-subscription-key>
